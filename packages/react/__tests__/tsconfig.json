{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "vitest/globals",
      "@testing-library/jest-dom"
    ],
    "baseUrl": "..",
    "paths": {
      "@stellar-wallet-connect/core": [
        "../../../core/src/index.ts"
      ]
    }
  },
  "include": [
    "./**/*",
    "../vitest.setup.ts"
  ]
}